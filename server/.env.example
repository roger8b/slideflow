# =============================================================================
# Slideflow Backend — Environment Variables
# Copie este arquivo para .env e preencha os valores
# =============================================================================

# -----------------------------------------------------------------------------
# Banco de dados (Turso embutido — arquivo local)
# -----------------------------------------------------------------------------
# Desenvolvimento: caminho relativo (executar sempre a partir de server/)
DATABASE_URL=file:local.db
# Produção VPS (Hostinger): caminho absoluto obrigatório
# DATABASE_URL=file:/var/data/slideflow/local.db

# -----------------------------------------------------------------------------
# Provedor LLM — escolha UM dos modos abaixo
# -----------------------------------------------------------------------------

# MODO 1: Ollama (local, zero custo — recomendado para testes)
# Requer Ollama rodando: ollama serve
# Modelos disponíveis: qwen3.5:9b, qwen2.5-coder:7b, llama3.1:8b, mistral:7b
OLLAMA_BASE_URL=http://127.0.0.1:11434
GEMINI_MODEL=qwen3.5:9b

# MODO 2: Gemini API (produção)
# Quando OLLAMA_BASE_URL estiver definido, Ollama tem precedência sobre Gemini
# GEMINI_API_KEY=sua_chave_aqui
# GEMINI_MODEL=googleai/gemini-2.0-flash-exp

# -----------------------------------------------------------------------------
# Configurações opcionais
# -----------------------------------------------------------------------------
CORS_ORIGIN=http://localhost:5173
LLM_CALL_TIMEOUT_MS=60000
RATE_LIMIT_REQUESTS_PER_HOUR=100
